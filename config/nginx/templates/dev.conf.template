# HTTPS server with SSL termination
server {
  listen ${HTTPS_PORT} ssl;
  http2 on;
  server_name _;

  # SSL configuration
  include /etc/nginx/snippets/ssl.conf;

  # Increase buffer sizes for OAuth callbacks with large headers
  include /etc/nginx/snippets/oauth-buffers.conf;

  root /usr/share/nginx/html;
  index index.html;

  # OAuth callback endpoints - proxy to API
  location ~ ^/signin-(oidc|microsoft|google|facebook|apple)$ {
    proxy_pass http://${API_HOST}:${API_PORT};
    include /etc/nginx/snippets/proxy-headers.conf;
    proxy_set_header X-Forwarded-Port ${SOURCE_PORT};
    include /etc/nginx/snippets/oauth-proxy.conf;
  }

  # OAuth signout callback endpoints - proxy to API
  location ~ ^/signout-callback-(oidc|microsoft|google|facebook|apple)$ {
    proxy_pass http://${API_HOST}:${API_PORT};
    include /etc/nginx/snippets/proxy-headers.conf;
    proxy_set_header X-Forwarded-Port ${SOURCE_PORT};
    include /etc/nginx/snippets/oauth-proxy.conf;
  }

  # Client-side auth routes (e.g. /auth/callback) are handled by the SPA
  # via the catch-all location / block below.
  # Server-side auth routes live under /api/v1/auth/ and are caught by location /api/.

  location /api/ {
    # Proxy API requests to backend
    gzip_types text/plain application/javascript application/json text/css application/xml;

    proxy_pass http://${API_HOST}:${API_PORT};
    # Upstream is HTTP only; SSL terminated at proxy
    # (api:8080)
    proxy_ssl_verify off;
    include /etc/nginx/snippets/proxy-headers.conf;
    proxy_set_header X-Forwarded-Port ${SOURCE_PORT};

    # Allow file uploads up to 10MB
    client_max_body_size 10M;
  }

  location / {
    proxy_pass http://${CLIENT_HOST}:${CLIENT_PORT};
    include /etc/nginx/snippets/proxy-headers.conf;
    proxy_set_header X-Forwarded-Port ${SOURCE_PORT};

    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
  }
}

# Dedicated HTTPS listener for OIDC passthrough (avoids panel rewrites and preserves assets)
server {
  listen ${OIDC_HTTPS_PORT} ssl;
  http2 on;
  server_name _;

  include /etc/nginx/snippets/ssl.conf;
  include /etc/nginx/snippets/oauth-buffers.conf;

  location / {
    proxy_pass http://${OIDC_HOST}:${OIDC_PORT};
    include /etc/nginx/snippets/proxy-headers.conf;
    proxy_set_header X-Forwarded-Port ${OIDC_HTTPS_PORT};
    proxy_set_header X-Forwarded-Proto https;
    proxy_set_header X-Forwarded-Host $host;
  }
}
