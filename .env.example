# FireFly Environment Configuration
#
# TLS/HTTPS Setup:
#   - All browser traffic goes through nginx edge on port 8443 (HTTPS)
#   - Uses self-signed certificate (infra/nginx/certs/localhost.{crt,key})
#   - Internal services use HTTP (postgres:5432, redis:6379, oidc:8080, server:3000, client:5173)
#   - OIDC provider uses internal URL (http://oidc:8080) for server-side discovery
#   - Callback and client origin use public URL (https://localhost:8443) for browser redirects
#
# Remote / LAN access:
#   Set PUBLIC_HOST to the hostname or IP that browsers use to reach this machine.
#   Default is "localhost" (local browser only). Example: PUBLIC_HOST=192.168.1.41

PUBLIC_HOST=localhost

# PostgreSQL
POSTGRES_USER=firefly
POSTGRES_PASSWORD=firefly_dev
POSTGRES_DB=firefly
DATABASE_URL=postgresql://firefly:firefly_dev@localhost:5432/firefly

# Redis
REDIS_URL=redis://localhost:6379

# Judge0
JUDGE0_URL=http://localhost:2358

# OIDC Provider
OIDC_ISSUER=http://oidc:8080
OIDC_CLIENT_ID=firefly
OIDC_CLIENT_SECRET=firefly-secret
OIDC_REDIRECT_URI=https://localhost:8443/api/v1/auth/callback

# JWT (server-side)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# LLM (LM Studio local)
LLM_PROVIDER=lmstudio
LLM_BASE_URL=http://localhost:1234
LLM_TIMEOUT_MS=300000

# Optional: Docker Compose Ollama profile overrides
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://ollama:11434

# Client origin (used by server for auth redirects)
CLIENT_ORIGIN=https://localhost:8443
# Server
PORT=3000
NODE_ENV=development
AUTO_SEED_DATA=true
EXECUTOR_PROVIDER=docker
EXECUTOR_DOCKER_WORKDIR=/executor-tmp

# Client
VITE_API_URL=http://localhost:3000/api/v1
